MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1682901824}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 65fd1e6473ed80b4a968dc4cc5bc1482, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questions:
  - questionTitle: Has perdido tu estuche favorito en el cole.
    options:
    - Me pongo a gritar porque estoy muy enfadado.
    - "Me quedo en silencio todo el d\xEDa y no hablo con nadie."
    - Respiro hondo y pido ayuda para buscarlo o avisar a alguien.
    - "Me burlo de otro ni\xF1o para sentirme mejor."
    correctIndex: 2
  - questionTitle: "Un compa\xF1ero te ha dicho algo que te doli\xF3."
    options:
    - Le digo algo peor para que aprenda.
    - "Le digo que me ha hecho da\xF1o y le pido que no lo repita."
    - "Me r\xEDo como si no me importara, aunque s\xED me duele."
    - "Ignoro a todos el resto del d\xEDa."
    correctIndex: 1
  - questionTitle: Hoy te ha salido mal un examen.
    options:
    - Soy tonto, nunca aprendo.
    - Es culpa del profe, el examen era injusto.
    - "Esta vez fue dif\xEDcil, pero puedo mejorar la pr\xF3xima si estudio distinto."
    - "Ya no quiero hacer m\xE1s deberes nunca."
    correctIndex: 2
  - questionTitle: Tu amigo no te ha invitado a su fiesta.
    options:
    - Triste, y lo bloqueo de todos lados.
    - "Triste, pero decido hablar con \xE9l para entender por qu\xE9."
    - Digo que me da igual aunque me duela por dentro.
    - Hago una fiesta yo y no lo invito tampoco.
    correctIndex: 1
  - questionTitle: Te han gritado en casa y te has sentido mal.
    options:
    - "Golpeo cosas en mi habitaci\xF3n."
    - Me encierro y lloro sin parar.
    - "Me callo y finjo que nada pas\xF3."
    - "Hablo con alguien de confianza y explico c\xF3mo me sent\xED."
    correctIndex: 3
  - questionTitle: Has visto a alguien llorar en clase.
    options:
    - "Me r\xEDo un poco con otros."
    - "Me alejo porque no s\xE9 qu\xE9 hacer."
    - Me acerco con cuidado y le pregunto si necesita ayuda.
    - Le digo que deje de llorar, que no es para tanto.
    correctIndex: 2
  - questionTitle: Alguien nuevo llega al grupo de amigos.
    options:
    - Me molesta porque va a cambiar todo.
    - Me hago el interesante para ignorarlo.
    - Le doy la bienvenida y trato de conocerlo.
    - Le pongo un apodo gracioso sin su permiso.
    correctIndex: 2
  - questionTitle: No te ha salido bien una manualidad que te gustaba.
    options:
    - La rompo, ya no me gusta.
    - Me frustro un poco, pero lo intento de nuevo o pido ayuda.
    - Le echo la culpa a los materiales.
    - Hago ruido o interrumpo a otros porque estoy enfadado.
    correctIndex: 1
  - questionTitle: "Un adulto te ha dicho que no puedes hacer algo que quer\xEDas."
    options:
    - Grito que no es justo.
    - "Pregunto por qu\xE9, y si puedo hacerlo en otro momento."
    - Me pongo a llorar en el suelo.
    - Me voy corriendo sin decir nada.
    correctIndex: 1
  - questionTitle: "Est\xE1s muy contento por algo y tus amigos no."
    options:
    - Les digo lo genial que soy.
    - Me lo guardo para no molestar.
    - "Lo comparto feliz, sin molestar a los dem\xE1s."
    - "Me r\xEDo de ellos por no estar igual de felices."
    correctIndex: 2
  questionTitleText: {fileID: 837417914}
  optionButtons:
  - {fileID: 1327849757}
  - {fileID: 457841068}
  - {fileID: 1544306652}
  - {fileID: 1976343944}
